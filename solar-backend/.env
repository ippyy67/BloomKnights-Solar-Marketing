# Copy this file to ".env" and fill in your real key.
# NEVER commit your real .env file to GitHub — .gitignore already blocks it.

GOOGLE_API_KEY=your_google_api_key_here

# The port your server runs on locally
PORT=3001

# Assumed average residential electricity rate for Orlando, FL (cents per kWh).
# Duke Energy Florida is the main utility here. This is a placeholder for the
# demo — swap in a real, current rate if you have time before judging.
ORLANDO_ELECTRICITY_RATE_PER_KWH=0.14

# Rough national average cost per watt for residential solar installation
# before tax credits. Also a placeholder — adjust if your team finds better data.
COST_PER_WATT_INSTALLED=3.00
